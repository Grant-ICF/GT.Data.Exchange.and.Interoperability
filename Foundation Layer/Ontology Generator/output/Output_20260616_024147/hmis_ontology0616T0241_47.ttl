hmis:HOPWAMedAssistedLivingFac a skos:ConceptScheme ;
  skos:prefLabel "HOPWAMedAssistedLivingFac"@en ;
  hmis:csvList "2.02.8"@en .

hmis:GeographyType a skos:ConceptScheme ;
  skos:prefLabel "GeographyType"@en ;
  hmis:csvList "2.03.4"@en .

hmis:HMISParticipationType a skos:ConceptScheme ;
  skos:prefLabel "HMISParticipationType"@en ;
  hmis:csvList "2.08.1"@en .

hmis:NameDataQuality a skos:ConceptScheme ;
  skos:prefLabel "NameDataQuality"@en ;
  hmis:csvList "3.01.5"@en .

hmis:SSNDataQuality a skos:ConceptScheme ;
  skos:prefLabel "SSNDataQuality"@en ;
  hmis:csvList "3.02.2"@en .

hmis:DOBDataQuality a skos:ConceptScheme ;
  skos:prefLabel "DOBDataQuality"@en ;
  hmis:csvList "3.03.2"@en .

hmis:LivingSituationOptionList a skos:ConceptScheme ;
  skos:prefLabel "Living Situation Option List"@en ;
  hmis:csvList "3.12.1"@en .

hmis:RentalSubsidyTypes a skos:ConceptScheme ;
  skos:prefLabel "RentalSubsidyTypes"@en ;
  hmis:csvList "3.12.A"@en .

hmis:RelationshipToHoH a skos:ConceptScheme ;
  skos:prefLabel "RelationshipToHoH"@en ;
  hmis:csvList "3.15.1"@en .

hmis:LengthOfStay a skos:ConceptScheme ;
  skos:prefLabel "LengthOfStay"@en ;
  hmis:csvList "3.917.2"@en .

hmis:TimesHomelessPastThreeYears a skos:ConceptScheme ;
  skos:prefLabel "TimesHomelessPastThreeYears"@en ;
  hmis:csvList "3.917.4"@en .

hmis:MonthsHomelessPastThreeYears a skos:ConceptScheme ;
  skos:prefLabel "MonthsHomelessPastThreeYears"@en ;
  hmis:csvList "3.917.5"@en .

hmis:ReasonNotInsured a skos:ConceptScheme ;
  skos:prefLabel "ReasonNotInsured"@en ;
  hmis:csvList "4.04.A"@en .

hmis:DisabilityResponse a skos:ConceptScheme ;
  skos:prefLabel "DisabilityResponse"@en ;
  hmis:csvList "4.10.2"@en .

